<!DOCTYPE html>
<html lang="en-AU">
<head>
  {{> head title="Gallery Creation"}}
  <style>
    body { margin: 0; font-family: Lato, sans-serif; background: #f7f7f8; color: #222; }
    .planner { display: grid; grid-template-columns: 340px 1fr; gap: 16px; padding: 16px; min-height: 100vh; box-sizing: border-box; }
    .panel { background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 12px; }
    .panel h2 { margin: 0 0 8px; font-family: Oswald, sans-serif; letter-spacing: .04em; font-size: 1.1rem; }
    .controls { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; }
    .controls button, .controls label { font: inherit; padding: 8px; border: 1px solid #bbb; border-radius: 6px; background: #fff; cursor: pointer; text-align: center; }
    .controls input { display: none; }
    #json-preview { width: 100%; height: 220px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12px; }
    #photo-list { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 8px; }
    .photo-tile { border: 1px solid #ccc; border-radius: 6px; padding: 4px; background: #fcfcfc; cursor: grab; user-select: none; }
    .photo-tile img { display: block; width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 4px; }
    .photo-title { margin: 4px 0 0; font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .canvas-wrap { background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 12px; overflow: auto; }
    #floorplan-svg { background: #fafafa; border: 1px solid #ddd; border-radius: 6px; }
    .cell { fill: #f2f2f2; stroke: #bbb; cursor: pointer; }
    .cell.active { fill: #d8ecff; stroke: #4f8fc9; }
    .cell.inactive { fill: #efefef; }
    .cell-label { font-size: 11px; fill: #666; pointer-events: none; }
    .placed { font-size: 11px; fill: #1b3b5c; pointer-events: none; }
    .hint { margin: 8px 0 0; font-size: 12px; color: #555; }
  </style>
</head>
<body>
  <main class="planner">
    <section class="panel">
      <h2>Gallery Builder (Dev)</h2>
      <div class="controls">
        <button id="export-json" type="button">Export JSON</button>
        <label for="import-json">Import JSON<input id="import-json" type="file" accept="application/json"></label>
        <button id="reset-layout" type="button">Reset Layout</button>
        <button id="download-layout" type="button">Download File</button>
      </div>
      <textarea id="json-preview" readonly></textarea>
      <p class="hint">Click cells to activate floor tiles. Drag photos onto an active cell wall (north/east/south/west).</p>
      <h2 style="margin-top: 12px;">Photos (Mock)</h2>
      <div id="photo-list"></div>
    </section>

    <section class="canvas-wrap">
      <svg id="floorplan-svg" width="760" height="760" role="img" aria-label="Gallery floor plan grid"></svg>
    </section>
  </main>

  <script src="https://d3js.org/d3.v7.min.js"></script>
  <script type="module" src="/js/gallery_creation.js"></script>
</body>
</html>
