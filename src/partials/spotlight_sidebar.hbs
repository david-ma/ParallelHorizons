<section id="spotlight_slider_panel" class="spotlight-panel" hidden>
  <header class="spotlight-panel-head">
    <h3>Spotlight tuning</h3>
    <p id="spotlight_rig_count" class="spotlight-meta">0 spotlights</p>
  </header>
  <p class="spotlight-hint">Adjustments apply to <strong>every</strong> artwork spotlight in the scene.</p>

  <details open class="spotlight-group">
    <summary>Mount</summary>
    <div class="spotlight-sliders" data-group="mount"></div>
  </details>

  <details open class="spotlight-group">
    <summary>Beam</summary>
    <div class="spotlight-sliders" data-group="beam"></div>
  </details>

  <details open class="spotlight-group">
    <summary>Emitter disc</summary>
    <div class="spotlight-sliders" data-group="emitter"></div>
  </details>

  <details open class="spotlight-group">
    <summary>Fixture (GLB)</summary>
    <div class="spotlight-sliders" data-group="fixture"></div>
  </details>

  <div class="spotlight-actions">
    <button id="spotlight_reset" type="button">Reset defaults</button>
    <button id="spotlight_copy_json" type="button">Copy JSON</button>
    <button id="spotlight_copy_code" type="button">Copy as TypeScript</button>
  </div>
  <p id="spotlight_export_status" class="spotlight-status" aria-live="polite"></p>
  <textarea id="spotlight_code_preview" class="spotlight-code-preview" readonly hidden aria-label="Exported TypeScript tuning"></textarea>
</section>

<style>
  .spotlight-panel {
    margin: 12px auto 8px;
    text-align: left;
    max-width: 340px;
    font-family: Lato, sans-serif;
    font-size: 12px;
  }
  .spotlight-panel-head { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin-bottom: 4px; }
  .spotlight-panel h3 { margin: 0; font-family: Oswald, sans-serif; letter-spacing: 0.06em; font-size: 1rem; }
  .spotlight-meta { margin: 0; color: #666; font-size: 11px; }
  .spotlight-hint { margin: 0 0 8px; color: #555; line-height: 1.4; }
  .spotlight-group { margin-bottom: 6px; border: 1px solid #e0e0e5; border-radius: 6px; padding: 0 8px 6px; background: #fafafa; }
  .spotlight-group summary { cursor: pointer; font-weight: 600; padding: 6px 0; list-style: none; }
  .spotlight-group summary::-webkit-details-marker { display: none; }
  .spotlight-sliders { display: grid; grid-template-columns: 1fr auto 52px; gap: 4px 8px; align-items: center; }
  .spotlight-sliders label { color: #333; }
  .spotlight-sliders input[type="range"] { width: 140px; margin: 0; }
  .spotlight-sliders output { font-variant-numeric: tabular-nums; text-align: right; color: #444; font-size: 11px; }
  .spotlight-actions { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
  .spotlight-actions button {
    font: inherit; font-size: 11px; padding: 6px 10px; border-radius: 6px;
    border: 1px solid #ccc; background: #fff; cursor: pointer;
  }
  .spotlight-actions button:hover { border-color: #888; }
  #spotlight_copy_code { background: #1a1a1e; color: #f2f2f7; border-color: #1a1a1e; }
  .spotlight-status { min-height: 1.2em; margin: 6px 0 0; color: #2d7a3a; font-size: 11px; }
  .spotlight-code-preview {
    width: 100%; height: 120px; margin-top: 8px; font-family: ui-monospace, Menlo, monospace;
    font-size: 10px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box;
  }
</style>
