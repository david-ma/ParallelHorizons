<section id="spotlight_slider_panel" style="margin: 12px auto 8px; text-align: left; max-width: 320px; font-family: Lato, sans-serif;">
  <h3 style="margin: 0 0 8px; font-family: Oswald, sans-serif; letter-spacing: 0.08em;">Spotlight Tuning (dev)</h3>
  <div style="display: grid; grid-template-columns: 1fr auto; gap: 6px 10px; align-items: center;">
    <label for="spotlight_intensity">Intensity</label><input id="spotlight_intensity" type="range" min="0" max="6" step="0.05">
    <label for="spotlight_distance">Distance</label><input id="spotlight_distance" type="range" min="1" max="20" step="0.1">
    <label for="spotlight_angle">Angle</label><input id="spotlight_angle" type="range" min="0.1" max="1.4" step="0.01">
    <label for="spotlight_penumbra">Penumbra</label><input id="spotlight_penumbra" type="range" min="0" max="1" step="0.01">
    <label for="spotlight_decay">Decay</label><input id="spotlight_decay" type="range" min="0" max="4" step="0.05">
    <label for="spotlight_x">Spotlight X</label><input id="spotlight_x" type="range" min="-20" max="20" step="0.01">
    <label for="spotlight_y">Light Y</label><input id="spotlight_y" type="range" min="1.5" max="6.5" step="0.01">
    <label for="spotlight_z">Spotlight Z</label><input id="spotlight_z" type="range" min="-3.5" max="-2.2" step="0.01">
    <label for="target_y">Target Y</label><input id="target_y" type="range" min="0.5" max="3.5" step="0.01">
    <label for="target_z">Target Z</label><input id="target_z" type="range" min="-3.2" max="-2.6" step="0.005">
    <label for="emitter_disc_radius">Emitter Radius</label><input id="emitter_disc_radius" type="range" min="0.01" max="0.3" step="0.005">
    <label for="emitter_disc_x">Emitter X</label><input id="emitter_disc_x" type="range" min="-0.5" max="0.5" step="0.005">
    <label for="emitter_disc_y">Emitter Y</label><input id="emitter_disc_y" type="range" min="-0.5" max="0.5" step="0.005">
    <label for="emitter_disc_z">Emitter Z</label><input id="emitter_disc_z" type="range" min="-0.5" max="0.5" step="0.005">
    <label for="emitter_disc_opacity">Emitter Opacity</label><input id="emitter_disc_opacity" type="range" min="0.05" max="1" step="0.01">
    <label for="fixture_scale">Fixture Scale</label><input id="fixture_scale" type="range" min="0.05" max="2.0" step="0.01">
    <label for="wall_mount_offset">Wall Offset</label><input id="wall_mount_offset" type="range" min="-1.0" max="10.0" step="0.01">
  </div>
  <div style="margin-top: 10px; display: flex; gap: 8px; align-items: center;">
    <button id="export_button" type="button">Export JSON</button>
    <small id="export_status" aria-live="polite"></small>
  </div>
</section>

