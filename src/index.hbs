<!DOCTYPE html>
<html lang="en-AU">
<head>
  {{> head title="Parallel Horizons"}}
</head>
<body class="page-home">
  <header class="home-header">
    <div class="home-header-inner">
      <a class="home-logo" href="/">Parallel Horizons</a>
      <nav class="home-nav" aria-label="Primary">
        <a href="/create">Editor</a>
      </nav>
    </div>
  </header>

  <main class="home-main">
    <section class="home-hero">
      <p class="home-eyebrow">3D virtual exhibitions</p>
      <h1>Walk through the galleries</h1>
      <p class="home-lead">
        Choose an exhibition below, then explore in the browser with WASD and mouse-look.
        Each gallery is built from a floorplan JSON file — layout, art placements, and wall finishes.
      </p>
    </section>

    <section class="home-galleries" aria-labelledby="galleries-heading">
      <h2 id="galleries-heading">Galleries</h2>
      <ul class="home-gallery-grid">
        {{#each galleries}}
        <li class="home-gallery-card">
          <h3>{{this.title}}</h3>
          <p>{{this.description}}</p>
          {{#if this.credit}}<p class="home-gallery-credit">{{this.credit}}</p>{{/if}}
          <a class="home-btn home-btn-primary" href="/view/{{this.slug}}">Enter gallery</a>
        </li>
        {{/each}}
      </ul>
    </section>

    <section class="home-features" aria-labelledby="features-heading">
      <h2 id="features-heading">For creators</h2>
      <p class="home-lead">Use the <a href="/create">floorplan editor</a> to arrange rooms and photos. Saves update the Parallel Horizons gallery.</p>
      <ul class="home-feature-grid">
        <li>JSON floorplan layout with placards</li>
        <li>Rapier physics and camera-relative movement</li>
        <li>Per-artwork spotlights and procedural wall materials</li>
        <li>Multiple published galleries from one viewer</li>
      </ul>
    </section>

    <section class="home-credits">
      <h2>Credits</h2>
      <p>
        Originally from <a href="https://twitter.com/owlsketch">@owlsketch</a>’s WebGL gallery concept.
        David Ma’s Tap Gallery exhibition. Met Monet set via legacy Open Access scraper.
        Spotlight model by iPoly3D on <a href="https://poly.pizza/m/YohOCmn0hO">Poly Pizza</a> (CC0).
      </p>
    </section>
  </main>

  <footer class="home-footer">
    <p>Thalia + Three.js</p>
  </footer>
</body>
</html>
