<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="content-type" content="text/html" charset="ISO-8859-1">
  <title>{{#if galleryTitle}}{{galleryTitle}} | {{/if}}3D Gallery</title>

  <link href="https://fonts.googleapis.com/css?family=Lato|Oswald" rel="stylesheet" type="text/css">
  <link rel="stylesheet" type="text/css" href="/css/index.css" media="screen">
  <style>
    img{
      -khtml-user-select: none;
      -o-user-select: none;
      -moz-user-select: none;
      -webkit-user-select: none;
      user-select: none;
    }
  </style>

  <style>
    /* Gamepad test stuff */
    .buttons, .axes {
      padding: 1em;
    }

    .axis {
      min-width: 200px;
      margin: 1em;
    }

    .button {
      padding: 1em;
      border-radius: 20px;
      border: 1px solid black;
      background-image: url(data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAIAAACQd1PeAAAAAXNSR0IArs4c6QAAAAxJREFUCNdjYPjPAAACAgEAqiqeJwAAAABJRU5ErkJggg==);
      background-size: 0% 0%;
      background-position: 50% 50%;
      background-repeat: no-repeat;
    }

    .pressed {
      border: 1px solid red;
    }

    #gamepadtest {
      display: none;
    }
    #gamepadtest.devmode {
      display: block;
    }
    #devonly {
      position: fixed;
    }
    #mobile_controls.hidden {
      display: none;
    }
    #mobile_controls {
      position: fixed;
      bottom: 0;
      background: red;
      width: 100%;
      height: 20%;
      display: flex;
    }
    #mob_info {
      height: 100%;
      width: 40%;
      background: green;
    }
    #mob_left {
      height: 100%;
      width: 30%;
    }
    #mob_right {
      height: 100%;
      width: 30%;
      background: blue;
    }
    .gallery-loading {
      position: fixed;
      inset: 0;
      z-index: 10000;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(28, 28, 30, 0.92);
      color: #f2f2f7;
      font-family: Lato, sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.04em;
    }
    .gallery-loading.hide {
      display: none;
    }
  </style>
</head>

<body>
  <div id="gallery-loading" class="gallery-loading">
    <p class="gallery-loading-text">Loading gallery layout…</p>
  </div>

  {{#unless production}}
  <div id="devonly">
    FPS: <span id="fps"></span>
  </div>
  <div id="gallery-minimap-wrap" aria-hidden="true">
    <canvas id="gallery-minimap"></canvas>
    <p id="gallery-minimap-legend">Minimap</p>
  </div>
  {{/unless}}

  <div id="background_menu"></div>

  <div id="menu">
    <div id="img_container">
      <img src="/img/david.jpg">
    </div>
    <div id="content">
      <h1>{{#if galleryTitle}}{{galleryTitle}}{{else}}Parallel Horizons{{/if}}</h1>
      <div>
        <p>A 3D gallery in your browser.</p>
        <p>A shallow copy of David Ma's exhibition from <a href="http://www.tapgallery.org.au/">Tap Gallery</a>.</p>
        <p>Thank you to <a href="https://twitter.com/owlsketch">@owlsketch</a> for the code.</p>
        <p>Thanks <a href="https://twitter.com/mapotato">@mapotato</a> for letting me know this was possible.</p>
      </div>
      <div>
        <p>Main Controls:</p>
        <p>W,A,S,D, Arrow Keys = Move Around</p>
        <p>Shift = Run</p>
        <p>Mouse = Look Around</p>
        <p>Spacebar = Jump</p>
      </div>
      <div id="play_button">
        <p>PLAY</p>
      </div>
      {{#unless production}}
      <button
        type="button"
        id="spotlight_tune_toggle"
        class="dev-only-btn"
        aria-expanded="false"
        aria-controls="spotlight_slider_panel"
      >Spotlight tuning</button>
      {{> spotlight_sidebar}}
      {{/unless}}
      <div id="gamepadtest"></div>
    </div>
  </div>

  <div id="mobile_controls" class="hidden">
    <div id="mob_left"><a>Back</a></div>
    <div id="mob_info"></div>
    <div id="mob_right"><a>Next</a></div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"
    integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
    crossorigin="anonymous"></script>

  <script>
    globalThis.GALLERY_FLOORPLAN_URL = "{{floorplanUrl}}";
    globalThis.GALLERY_DEV_TOOLS = {{#if production}}false{{else}}true{{/if}};
  </script>
  <script type="text/javascript" src="/js/Detector.js"></script>
  <script type="module" src="/js/main.js"></script>
  <script type="text/javascript" src="/js/gamepadtest.js"></script>

  <script>
    function devmode() {
      console.log("Toggling dev mode");
      $("#gamepadtest").toggleClass("devmode");
    }

    function toggleDevSpotlightPanel() {
      if (!globalThis.GALLERY_DEV_TOOLS) return;
      var host = window.location.hostname;
      var isDev = host === "localhost" || host === "127.0.0.1";
      if (isDev) document.body.classList.add("dev-mode");
    }

    globalThis.toggleDevSpotlightPanel = toggleDevSpotlightPanel;
    globalThis.devmode = devmode;
    toggleDevSpotlightPanel();
  </script>
</body>
</html>
